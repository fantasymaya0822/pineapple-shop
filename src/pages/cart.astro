---
import Layout from '../layouts/Layout.astro';
---

<Layout title="購物車">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-secondary mb-8">🛒 購物車</h1>

    <!-- Empty cart -->
    <div id="empty-cart" class="hidden text-center py-16">
      <div class="text-6xl mb-4">🍍</div>
      <p class="text-gray-500 text-lg mb-6">購物車是空的，快去挑選美味鳳梨吧！</p>
      <a href="/products" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-bold hover:bg-primary-dark transition-colors">
        前往選購 →
      </a>
    </div>

    <!-- Cart items -->
    <div id="cart-items" class="space-y-4 mb-8"></div>

    <!-- Cart summary -->
    <div id="cart-summary" class="hidden bg-white rounded-2xl p-6 shadow-sm mb-8">
      <div class="flex justify-between items-center text-lg mb-2">
        <span class="text-gray-600">商品小計</span>
        <span id="subtotal" class="font-bold">NT$0</span>
      </div>
      <div class="flex justify-between items-center text-lg mb-4">
        <span class="text-gray-600">運費</span>
        <span id="shipping" class="font-bold text-secondary-light">免運費</span>
      </div>
      <div class="border-t pt-4 flex justify-between items-center text-xl">
        <span class="font-bold text-secondary">合計</span>
        <span id="total" class="font-black text-primary text-2xl">NT$0</span>
      </div>
    </div>

    <!-- Checkout form -->
    <div id="checkout-form" class="hidden bg-white rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-secondary mb-6">📋 訂購資訊</h2>
      <form id="order-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">姓名 *</label>
          <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">電話 *</label>
          <input type="tel" name="phone" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">收件地址 *</label>
          <input type="text" name="address" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">付款方式 *</label>
          <select name="payment" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none">
            <option value="transfer">銀行轉帳</option>
            <option value="cod">貨到付款（+NT$30）</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">備註</label>
          <textarea name="note" rows="3" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="特殊需求請在此備註..."></textarea>
        </div>
        <button type="submit" class="w-full bg-primary text-white py-3 rounded-full font-bold text-lg hover:bg-primary-dark transition-colors">
          送出訂單
        </button>
        <p class="text-xs text-gray-400 text-center">送出後我們會透過 LINE 或電話與您確認訂單</p>
      </form>
    </div>

    <!-- Order success -->
    <div id="order-success" class="hidden text-center py-16 bg-white rounded-2xl shadow-sm">
      <div class="text-6xl mb-4">🎉</div>
      <h2 class="text-2xl font-bold text-secondary mb-2">訂單已送出！</h2>
      <p class="text-gray-500 mb-6">我們會儘快透過電話或 LINE 與您確認訂單詳情。</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://line.me/ti/p/@your-line-id"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#06C755] text-white px-6 py-3 rounded-full font-bold hover:brightness-110 transition"
        >
          加 LINE 追蹤訂單
        </a>
        <a href="/" class="inline-block border-2 border-secondary text-secondary px-6 py-3 rounded-full font-bold hover:bg-secondary hover:text-white transition-colors">
          回首頁
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  type CartItem = {
    id: string;
    name: string;
    price: number;
    image: string;
    unit: string;
    quantity: number;
  };

  function getCart(): CartItem[] {
    return JSON.parse(localStorage.getItem('cart') || '[]');
  }

  function saveCart(cart: CartItem[]) {
    localStorage.setItem('cart', JSON.stringify(cart));
    document.dispatchEvent(new Event('cart-updated'));
  }

  function renderCart() {
    const cart = getCart();
    const itemsEl = document.getElementById('cart-items')!;
    const emptyEl = document.getElementById('empty-cart')!;
    const summaryEl = document.getElementById('cart-summary')!;
    const formEl = document.getElementById('checkout-form')!;

    if (cart.length === 0) {
      emptyEl.classList.remove('hidden');
      itemsEl.innerHTML = '';
      summaryEl.classList.add('hidden');
      formEl.classList.add('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    summaryEl.classList.remove('hidden');
    formEl.classList.remove('hidden');

    itemsEl.innerHTML = cart.map(item => `
      <div class="bg-white rounded-xl p-4 shadow-sm flex items-center gap-4">
        <img src="${item.image}" alt="${item.name}" class="w-16 h-16 object-contain bg-warm-dark rounded-lg p-2" />
        <div class="flex-1">
          <h3 class="font-bold text-secondary">${item.name}</h3>
          <p class="text-sm text-gray-400">${item.unit}</p>
        </div>
        <div class="flex items-center gap-2">
          <button data-action="decrease" data-id="${item.id}" class="w-8 h-8 rounded-full border border-gray-300 flex items-center justify-center hover:bg-gray-100 text-lg">−</button>
          <span class="w-8 text-center font-bold">${item.quantity}</span>
          <button data-action="increase" data-id="${item.id}" class="w-8 h-8 rounded-full border border-gray-300 flex items-center justify-center hover:bg-gray-100 text-lg">+</button>
        </div>
        <div class="text-right min-w-[80px]">
          <div class="font-bold text-primary">NT$${item.price * item.quantity}</div>
        </div>
        <button data-action="remove" data-id="${item.id}" class="text-gray-400 hover:text-red-500 transition-colors" title="移除">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    `).join('');

    const subtotal = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    const totalBoxes = cart.reduce((sum, item) => sum + item.quantity, 0);
    const shipping = totalBoxes >= 2 ? 0 : 150;

    document.getElementById('subtotal')!.textContent = `NT$${subtotal}`;
    document.getElementById('shipping')!.textContent = shipping === 0 ? '免運費' : `NT$${shipping}`;
    document.getElementById('total')!.textContent = `NT$${subtotal + shipping}`;

    // Bind buttons
    itemsEl.querySelectorAll('button[data-action]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = (e.currentTarget as HTMLElement);
        const action = target.dataset.action!;
        const id = target.dataset.id!;
        const cart = getCart();
        const item = cart.find(i => i.id === id);
        if (!item) return;

        if (action === 'increase') item.quantity += 1;
        if (action === 'decrease') item.quantity = Math.max(1, item.quantity - 1);
        if (action === 'remove') {
          const idx = cart.indexOf(item);
          cart.splice(idx, 1);
        }

        saveCart(cart);
        renderCart();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderCart();

    document.getElementById('order-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = new FormData(form);
      const cart = getCart();

      // Build LINE message
      const orderText = cart.map(item =>
        `${item.name} x${item.quantity} = NT$${item.price * item.quantity}`
      ).join('\n');

      const message = `
【新訂單】
姓名：${data.get('name')}
電話：${data.get('phone')}
地址：${data.get('address')}
付款：${data.get('payment') === 'transfer' ? '銀行轉帳' : '貨到付款'}
---
${orderText}
---
備註：${data.get('note') || '無'}
      `.trim();

      console.log('Order:', message);

      // Clear cart and show success
      localStorage.removeItem('cart');
      document.dispatchEvent(new Event('cart-updated'));
      document.getElementById('cart-items')!.innerHTML = '';
      document.getElementById('cart-summary')!.classList.add('hidden');
      document.getElementById('checkout-form')!.classList.add('hidden');
      document.getElementById('order-success')!.classList.remove('hidden');
    });
  });
</script>
