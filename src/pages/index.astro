---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const featured = products.filter(p => p.featured);
---

<Layout title="首頁">
  <Hero />

  <!-- Featured Products -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-secondary mb-2">精選鳳梨</h2>
      <p class="text-gray-500">嚴選當季最甜的品種，限量供應中</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/products" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-bold hover:bg-primary hover:text-white transition-colors">
        查看所有商品 →
      </a>
    </div>
  </section>

  <!-- Why Us -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-secondary text-center mb-12">為什麼選擇德品果園？</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🌞</div>
          <h3 class="text-lg font-bold text-secondary mb-2">陽光自然熟成</h3>
          <p class="text-gray-500 text-sm">不催熟、不搶收，等待每顆鳳梨達到最佳甜度才採收。</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🚚</div>
          <h3 class="text-lg font-bold text-secondary mb-2">產地直送</h3>
          <p class="text-gray-500 text-sm">從果園到餐桌最短距離，採收後 24 小時內出貨。</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🌿</div>
          <h3 class="text-lg font-bold text-secondary mb-2">友善土地</h3>
          <p class="text-gray-500 text-sm">減少化學用藥，善待土地與環境，種出安心好水果。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-secondary mb-4">想吃最甜的鳳梨？</h2>
      <p class="text-gray-500 mb-8">加入我們的 LINE 官方帳號，第一時間掌握產季資訊與限量優惠！</p>
      <a
        href="https://line.me/ti/p/@your-line-id"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#06C755] text-white px-8 py-4 rounded-full font-bold text-lg hover:brightness-110 transition shadow-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        加入 LINE 好友
      </a>
    </div>
  </section>
</Layout>
